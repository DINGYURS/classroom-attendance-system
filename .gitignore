# ==========================
#  【核心】全局通用规则 (Global)
#   无需加前缀，自动递归匹配所有子目录
# ==========================
# OS & Editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj
*.sln

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ==========================
#  Frontend (Vue3)
# ==========================
node_modules/
dist/
dist-ssr/
*.local


# ==========================
#  Backend (Spring Boot)
# ==========================
# Maven
target/
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# IDE & Tools (Removed leading slash to fix matching)
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
*.iws
*.iml
*.ipr

# NetBeans (Removed leading slash)
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/


# ==========================
#  Algorithm Service (Python)
# ==========================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
# 注意：backend 也有 build，这里规则是通用的，不用重复写
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Model Weights (保留你的规则)
weights/*.pt
weights/*.onnx
!weights/.gitkeep

# Temporary files (Removed leading slash)
tmp/
*.tmp

# Coverage
.coverage
htmlcov/
.tox/
.pytest_cache/